{
  "name": "front-end",
  "version": "1.0.0",
  "description": "Stenter Chemical Dosage — Electron frontend",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.stenter.chemical-dosage",
    "productName": "Stenter Chemical Dosage",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stenter Chemical Dosage"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**",
      "!**/*.map"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/STENTER-Chemical-Dosage/front-end.git"
  },
  "keywords": [
    "electron",
    "stenter",
    "chemical-dosage"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/STENTER-Chemical-Dosage/front-end/issues"
  },
  "homepage": "https://github.com/STENTER-Chemical-Dosage/front-end#readme",
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "pg": "^8.19.0",
    "xlsx": "^0.18.5"
  }
}
